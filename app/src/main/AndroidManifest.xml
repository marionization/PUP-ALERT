<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.seriousmode">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_school_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_school_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.SeriousMode">

        <service
            android:name="Activity.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name="Activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="Activity.ResetPasswordActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="seriousmode.page.link"
                    android:pathPrefix="/reset"
                    android:scheme="https" />
            </intent-filter>
        </activity>

        <activity
            android:name="Activity.SubmitReportActivity"
            android:exported="false"
            android:label="Submit Report"
            android:theme="@style/Theme.SeriousMode" />

        <activity
            android:name="Activity.NextActivity"
            android:exported="false"
            android:label="@string/title_activity_next"
            android:theme="@style/Theme.SeriousMode" />

        <activity
            android:name="Activity.ReportDetailActivity"
            android:exported="false"
            android:label="Report Details"
            android:theme="@style/Theme.SeriousMode" />

        <activity
            android:name="Activity.RegisterActivity"
            android:exported="false"
            android:label="Register"
            android:theme="@style/Theme.SeriousMode" />

        <activity
            android:name="Activity.ForgotPasswordActivity"
            android:exported="false"
            android:label="Forgot Password"
            android:theme="@style/Theme.SeriousMode" />

        <activity
            android:name="Activity.OtpVerificationActivity"
            android:exported="false"
            android:label="OTP Verification"
            android:theme="@style/Theme.SeriousMode" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

    </application>
</manifest>
